@import "../../app.wxss";

.request-card {
  margin-bottom: 22rpx;
}

.member-name {
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.request-actions {
  display: flex;
  justify-content: flex-end;
  gap: 18rpx;
  margin-top: 24rpx;
}

.small-button {
  min-width: 128rpx;
  padding: 14rpx 22rpx;
  border-radius: 18rpx;
  color: #ffffff;
  text-align: center;
  font-size: 26rpx;
  font-weight: 900;
}

.small-button.reject {
  background: #8f1d1d;
}

.small-button.approve {
  background: #8f1d1d;
}

.empty {
  color: #222222;
}

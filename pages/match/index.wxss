@import "../../app.wxss";

.compact-hero {
  padding-bottom: 34rpx;
}

.match-card {
  margin-bottom: 24rpx;
}

.match-name {
  margin-left: 16rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.score {
  color: #222222;
  font-size: 30rpx;
  font-weight: 900;
}

.source-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.source-pill {
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #8f1d1d;
  font-size: 22rpx;
  font-weight: 900;
}

.topic {
  margin: 20rpx 0;
  color: #222222;
  font-size: 26rpx;
  line-height: 1.45;
}

.meta {
  margin-top: 14rpx;
  font-size: 24rpx;
}
